{
  "name": "@rising-company/mesh-maker-react",
  "version": "0.1.0",
  "description": "React component for mesh-maker WebGL dot grid",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
